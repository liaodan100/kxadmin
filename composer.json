{
    "name": "liaodan/kxadmin",
    "description": "KxAdmin System Module Framework",
    "type": "library",
    "version": "1.0.4",
    "require": {
        "php": "^8.1",
        "illuminate/auth": "^10.0",
        "illuminate/contracts": "^10.0",
        "illuminate/database": "^10.0",
        "illuminate/http": "^10.0",
        "illuminate/routing": "^10.0",
        "illuminate/support": "^10.0",
        "tymon/jwt-auth": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "KxAdmin\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "KxAdmin\\AdminServiceProvider"
            ]
        }
    }
}
